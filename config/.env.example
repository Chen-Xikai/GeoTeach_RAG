# GeoTeach AI Agent 环境变量配置

# ==================== API配置 ====================
# SiliconFlow API (用于Embedding和LLM)
# 注册地址: https://cloud.siliconflow.cn/
# 注册后在 https://cloud.siliconflow.cn/account/ak 获取API Key
SILICONFLOW_API_KEY=your-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# Embedding模型
EMBEDDING_MODEL=BAAI/bge-large-zh-v1.5

# Rerank模型
RERANK_ENABLED=true
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# LLM模型
LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ==================== 服务配置 ====================
# Web API服务
WEB_HOST=0.0.0.0
WEB_PORT=${PORT:-9767}

# 允许的跨域来源（逗号分隔，*表示全部）
ALLOWED_ORIGINS=*

# ==================== 密码配置 ====================
# 访问密码（留空则无需密码即可访问）
ACCESS_PASSWORD=
# 管理员密码（留空则无管理员权限区分）
ADMIN_PASSWORD=

# ==================== Milvus配置 ====================
MILVUS_DB_PATH=data/milvus.db

# ==================== RAG配置 ====================
RETRIEVAL_K=5
RETRIEVAL_FETCH_K=15
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ==================== 应用配置 ====================
DOCS_DIR=data/docs
GENERATED_DIR=data/generated
LOG_LEVEL=INFO
